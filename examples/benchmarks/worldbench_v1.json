      "id": "vscode-ext-activate-01",
      "name": "VS Code extension activation 1",
      "prompt": "This is a VS Code extension workspace. Fix package.json so activationEvents includes onCommand:sonec.hello1 and add that command to contributes.commands with title 'Sonec: Hello 1'.",
      "checks": [
        {
          "kind": "file_contains",
          "path": "package.json",
          "contains": "onCommand:sonec.hello1",
          "command_exit_zero": null,
          "pattern": null
        },
        {
          "kind": "file_contains",
          "path": "package.json",
          "contains": "Sonec: Hello 1",
          "command_exit_zero": null,
          "pattern": null
        }
      ],
      "tags": [
        "vscode",
        "extension",
        "typescript",
        "ide"
      ],
      "timeout_s": 300.0,
      "difficulty": "medium",
      "seed_files": {
        "package.json": "{\n  \"name\": \"sonec-vscode-ext-1\",\n  \"displayName\": \"Sonec Ext 1\",\n  \"version\": \"0.0.1\",\n  \"engines\": {\n    \"vscode\": \"^1.85.0\"\n  },\n  \"activationEvents\": [\n    \"onCommand:sonec.hello\"\n  ],\n  \"contributes\": {\n    \"commands\": [\n      {\n        \"command\": \"sonec.hello\",\n        \"title\": \"Sonec: Hello\"\n      }\n    ]\n  },\n  \"main\": \"./out/extension.js\"\n}\n",
        "src/extension.ts": "import * as vscode from 'vscode';\n\nexport function activate(context: vscode.ExtensionContext) {\n  const disposable = vscode.commands.registerCommand('sonec.hello', () => {\n    vscode.window.showInformationMessage('Hello');\n  });\n  context.subscriptions.push(disposable);\n}\n",
        "tsconfig.json": "{\n  \"compilerOptions\": {\n    \"module\": \"commonjs\",\n    \"target\": \"ES2020\",\n    \"outDir\": \"out\"\n  }\n}\n"
      }
    },
